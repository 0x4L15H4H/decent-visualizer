# The backend image builds from the repo root (it needs config.env), so keep
# everything except what the image needs out of the build context.
.git
.github
.claude
frontend
infra
scripts
schemas
docs
*.md
docker-compose.yml
Makefile

# Never bake local dev secrets or caches into the image.
backend/.env
**/.env
**/__pycache__
**/*.pyc
